# 阿里云OTS访问密钥 ID
TABLESTORE_ACCESS_KEY_ID=your-access-key-id

# 阿里云OTS访问密钥 Secret
TABLESTORE_ACCESS_KEY_SECRET=your-access-key-secret

# 环境，如 development, production
# 生产环境，需要设置为production使用VPC内网访问OTS
# APP_ENV=production
# 开发环境，需要设置为development使用公网访问OTS
APP_ENV=development

# 地域请在各表的 tables.yaml 中配置 regionId（勿再用环境变量传地域）。

# tablestore表格配置路径
SIMPLEOTSGO_TABLES_PATH=./config/tables.yaml
